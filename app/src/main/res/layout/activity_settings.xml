<?xml version="1.0" encoding="utf-8"?>
<!-- Cerinta 4 Lab 7: Layout pentru activitatea de setari -->
<!-- Utilizatorul seteaza dimensiunea si culoarea textului -->
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="24dp"
    tools:context=".SettingsActivity">

    <!-- Titlu activitate setari -->
    <TextView
        android:id="@+id/titleSettings"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="⚙️  Setări Text"
        android:textSize="24sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:layout_marginTop="16dp" />

    <!-- Label pentru dimensiunea textului -->
    <TextView
        android:id="@+id/labelTextSize"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Dimensiune text:"
        android:textSize="16sp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/titleSettings"
        android:layout_marginTop="40dp" />

    <!-- Afiseaza valoarea curenta a dimensiunii textului -->
    <TextView
        android:id="@+id/tvTextSizeValue"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="14 SP"
        android:textSize="16sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@+id/labelTextSize"
        app:layout_constraintBottom_toBottomOf="@+id/labelTextSize" />

    <!-- SeekBar pentru a alege dimensiunea textului (8sp - 30sp) -->
    <!-- progress = valoarea curenta, max = 22 (adica 8 + 22 = 30 maxim) -->
    <SeekBar
        android:id="@+id/seekBarTextSize"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:max="22"
        android:progress="6"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/labelTextSize"
        android:layout_marginTop="12dp" />

    <!-- Label pentru culoarea textului -->
    <TextView
        android:id="@+id/labelTextColor"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Culoare text:"
        android:textSize="16sp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/seekBarTextSize"
        android:layout_marginTop="32dp" />

    <!-- Spinner (dropdown) pentru selectarea culorii textului -->
    <Spinner
        android:id="@+id/spinnerTextColor"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:minHeight="48dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/labelTextColor"
        android:layout_marginTop="12dp" />

    <!-- TextView de previzualizare — arata cum va arata textul cu setarile alese -->
    <TextView
        android:id="@+id/tvPreview"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Previzualizare text"
        android:textSize="14sp"
        android:gravity="center"
        android:padding="16dp"
        android:layout_marginTop="32dp"
        android:background="#22888888"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/spinnerTextColor" />

    <!-- Buton de salvare setari -->
    <Button
        android:id="@+id/btnSaveSettings"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="💾  Salvează Setările"
        android:textSize="16sp"
        android:layout_marginTop="32dp"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/tvPreview" />

</androidx.constraintlayout.widget.ConstraintLayout>

<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_gradient_dark"
    android:fillViewport="true"
    android:scrollbars="none">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- ═══ AMBIENT GLOW EFFECT ═══ -->
        <View
            android:layout_width="300dp"
            android:layout_height="300dp"
            android:layout_gravity="top|end"
            android:layout_marginTop="-80dp"
            android:layout_marginEnd="-80dp"
            android:background="@drawable/glow_circle"
            android:alpha="0.3" />

        <View
            android:layout_width="250dp"
            android:layout_height="250dp"
            android:layout_gravity="bottom|start"
            android:layout_marginBottom="-60dp"
            android:layout_marginStart="-60dp"
            android:background="@drawable/glow_circle"
            android:alpha="0.2" />

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/main"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingTop="16dp"
            android:paddingBottom="24dp"
            tools:context=".AddMasinaActivity">

            <!-- ═══ HEADER: CAR ICON + TITLE ═══ -->
            <ImageView
                android:id="@+id/carEmoji"
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:src="@drawable/skoda"
                android:contentDescription="Sigla Skoda"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                android:layout_marginTop="4dp" />

            <TextView
                android:id="@+id/headerTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="CONFIGURATOR AUTO"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="@color/neon_cyan"
                android:letterSpacing="0.25"
                android:layout_marginTop="4dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/carEmoji" />

            <TextView
                android:id="@+id/headerSubtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Construiește-ți mașina visurilor"
                android:textSize="13sp"
                android:textColor="@color/text_dim"
                android:letterSpacing="0.05"
                android:layout_marginTop="2dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/headerTitle" />

            <View
                android:id="@+id/neonLine"
                android:layout_width="0dp"
                android:layout_height="2dp"
                android:layout_marginTop="16dp"
                android:layout_marginStart="40dp"
                android:layout_marginEnd="40dp"
                android:background="@drawable/neon_divider"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/headerSubtitle" />

            <!-- ═══ CARD 1: MARCA ═══ -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/cardMarca"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:background="@drawable/card_glow"
                android:padding="18dp"
                android:elevation="8dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/neonLine">

                <TextView
                    android:id="@+id/Marca"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🔧  MARCA"
                    android:textColor="@color/neon_cyan"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.3"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <EditText
                    android:id="@+id/marca_edit_Text"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:minHeight="50dp"
                    android:background="@drawable/input_neon"
                    android:inputType="text"
                    android:hint="Ex: BMW, Audi, Mercedes..."
                    android:textColor="@color/white"
                    android:textColorHint="@color/text_dim"
                    android:textSize="16sp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/Marca" />

            </androidx.constraintlayout.widget.ConstraintLayout>

            <!-- ═══ CARD 2: AN FABRICATIE ═══ -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/cardAn"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/card_glow"
                android:padding="18dp"
                android:elevation="8dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/cardMarca">

                <TextView
                    android:id="@+id/labelAnFabricatie"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📅  AN FABRICAȚIE"
                    android:textColor="@color/neon_cyan"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.3"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <EditText
                    android:id="@+id/editTextAnFabricatie"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:minHeight="50dp"
                    android:background="@drawable/input_neon"
                    android:inputType="number"
                    android:hint="Ex: 2024"
                    android:textColor="@color/white"
                    android:textColorHint="@color/text_dim"
                    android:textSize="16sp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/labelAnFabricatie" />

            </androidx.constraintlayout.widget.ConstraintLayout>

            <!-- ═══ CARD 3: PROPULSIE + CULOARE ═══ -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/cardOptions"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/card_glow"
                android:padding="18dp"
                android:elevation="8dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/cardAn">

                <TextView
                    android:id="@+id/esteElectrica"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="⚡  PROPULSIE"
                    android:textColor="@color/neon_cyan"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.3"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <CheckBox
                    android:id="@+id/checkboxElectrica"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="  Mașină 100% Electrică  ⚡"
                    android:textColor="@color/text_light"
                    android:textSize="15sp"
                    android:buttonTint="@color/neon_cyan"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/esteElectrica" />

                <View
                    android:id="@+id/divider1"
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_marginTop="14dp"
                    android:background="@color/divider"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/checkboxElectrica" />

                <TextView
                    android:id="@+id/labelCuloare"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:text="🎨  CULOARE CAROSERIE"
                    android:textColor="@color/neon_cyan"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.3"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/divider1" />

                <Spinner
                    android:id="@+id/culoareMasina"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:minHeight="48dp"
                    android:background="@drawable/spinner_neon"
                    android:padding="12dp"
                    android:contentDescription="Selectati culoarea masinii"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/labelCuloare" />

            </androidx.constraintlayout.widget.ConstraintLayout>

            <!-- ═══ CARD 4: RATING VITEZĂ ═══ -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/cardRating"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/card_glow"
                android:padding="18dp"
                android:elevation="8dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/cardOptions">

                <TextView
                    android:id="@+id/labelRating"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🚀  PERFORMANȚĂ"
                    android:textColor="@color/neon_cyan"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.3"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <TextView
                    android:id="@+id/ratingHint"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="Evaluează viteza maximă"
                    android:textColor="@color/text_dim"
                    android:textSize="11sp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/labelRating" />

                <RatingBar
                    android:id="@+id/ratingBarMasinaVItezaMaxima"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:progressTint="@color/rating_star"
                    android:progressBackgroundTint="#33FFFFFF"
                    android:secondaryProgressTint="@color/divider"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/ratingHint" />

            </androidx.constraintlayout.widget.ConstraintLayout>

            <!-- ═══ CARD 5: DATA FABRICATIEI (Cerinta 2 — atribut Date) ═══ -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/cardData"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/card_glow"
                android:padding="18dp"
                android:elevation="8dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/cardRating">

                <TextView
                    android:id="@+id/labelData"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📅  DATA FABRICAȚIEI"
                    android:textColor="@color/neon_cyan"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.3"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <Button
                    android:id="@+id/btnSelectData"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:minHeight="48dp"
                    android:background="@drawable/input_neon"
                    android:text="Selectează data"
                    android:textColor="@color/text_light"
                    android:textSize="14sp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/labelData" />

            </androidx.constraintlayout.widget.ConstraintLayout>

            <!-- ═══ BUTON SALVARE — GRADIENT NEON ═══ -->
            <Button
                android:id="@+id/salvare"
                android:layout_width="0dp"
                android:layout_height="60dp"
                android:layout_marginTop="28dp"
                android:layout_marginBottom="16dp"
                android:layout_marginStart="24dp"
                android:layout_marginEnd="24dp"
                android:background="@drawable/button_ripple"
                android:text="💾  SALVEAZĂ MAȘINA"
                android:textColor="@color/white"
                android:textSize="16sp"
                android:textStyle="bold"
                android:letterSpacing="0.15"
                android:elevation="12dp"
                android:stateListAnimator="@null"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/cardData" />

        </androidx.constraintlayout.widget.ConstraintLayout>

    </FrameLayout>
</ScrollView>
<?xml version="1.0" encoding="utf-8"?>
<!-- Lab 9: Layout personalizat pentru un element din ListView-ul cu imagini.
     Fiecare rand contine o imagine (ImageView) descarcata din internet
     si un text de descriere (TextView) afisat in dreapta imaginii. -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:padding="12dp"
    android:gravity="center_vertical">

    <!-- Lab 9: ImageView pentru imaginea descarcata din internet cu Executors.
         Initial arata un placeholder gri pana cand imaginea se incarca. -->
    <ImageView
        android:id="@+id/ivItemImage"
        android:layout_width="120dp"
        android:layout_height="80dp"
        android:scaleType="centerCrop"
        android:background="#EEEEEE"
        android:contentDescription="Imagine masina" />

    <!-- Lab 9: TextView cu descrierea scurta a imaginii, afisat in dreapta -->
    <TextView
        android:id="@+id/tvItemDescriere"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:layout_marginStart="12dp"
        android:textSize="15sp"
        android:textColor="#333333" />

</LinearLayout>

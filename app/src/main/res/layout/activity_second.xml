<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".SecondActivity">

    <Button
        android:id="@+id/button3"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/second_button_label"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:layout_marginTop="32dp" />

    <Button
        android:id="@+id/button_to_masin"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Adauga masina"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/button3"
        android:layout_marginTop="16dp" />

    <TextView
        android:id="@+id/tvMarca"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Marca: -"
        android:textSize="16sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/button_to_masin"
        android:layout_marginTop="32dp" />

    <TextView
        android:id="@+id/tvElectrica"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Electrica: -"
        android:textSize="16sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/tvMarca"
        android:layout_marginTop="8dp" />

    <TextView
        android:id="@+id/tvAn"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="An fabricatie: -"
        android:textSize="16sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/tvElectrica"
        android:layout_marginTop="8dp" />

    <TextView
        android:id="@+id/tvCuloare"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Culoare: -"
        android:textSize="16sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/tvAn"
        android:layout_marginTop="8dp" />

    <TextView
        android:id="@+id/tvViteza"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Rating viteza: -"
        android:textSize="16sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/tvCuloare"
        android:layout_marginTop="8dp" />

</androidx.constraintlayout.widget.ConstraintLayout>